#!/usr/bin/env sh
set -eu

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

if command -v python >/dev/null 2>&1; then
  python_cmd="python"
elif command -v python3 >/dev/null 2>&1; then
  python_cmd="python3"
else
  echo "Python is required to run deploy readiness checks." >&2
  exit 1
fi

echo "Running pre-push deploy readiness checks..."
"$python_cmd" scripts/verify_deploy_readiness.py
