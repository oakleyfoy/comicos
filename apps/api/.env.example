APP_ENV=development
APP_NAME=ComicOS API
API_HOST=127.0.0.1
API_PORT=8000
DATABASE_URL=postgresql+pg8000://postgres:postgres@localhost:5433/comic_os
DEBUG_RUNTIME=false
SECRET_KEY=dev-secret-key-32-bytes-minimum-1234
ACCESS_TOKEN_EXPIRE_MINUTES=60
FRONTEND_URL=http://127.0.0.1:5173
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/gmail/connect/callback
RETAILER_CREDENTIAL_ENCRYPTION_KEY=
MIDTOWN_SYNC_ENABLED=true
RETAILER_SYNC_DEFAULT_LIMIT_ORDERS=25
OPENAI_API_KEY=
PHOTO_IMPORT_VISION_SANDBOX=false
PHOTO_IMPORT_VISION_SANDBOX_MODEL=gpt-4o
REDIS_URL=redis://localhost:6379/0
OPS_ADMIN_EMAILS=

# P97 — historical catalog import (offline jobs; not scan-time)
COMICVINE_API_KEY=
COMICVINE_API_BASE_URL=
CATALOG_STORAGE_ROOT=./data/catalog
CATALOG_COVER_STORAGE_ROOT=./data/catalog/covers
CATALOG_IMPORT_SLEEP_SECONDS=1
CATALOG_IMPORT_BATCH_SIZE=100
CATALOG_IMPORT_MAX_RETRIES=3
CATALOG_IMPORT_USER_AGENT=ComicOS-CatalogImporter/1.0
LOCG_IMPORT_ENABLED=true
GCD_IMPORT_ENABLED=true
COMICVINE_MAX_REQUESTS_PER_RESOURCE_HOUR=200
COMICVINE_HTTP_CACHE_ENABLED=true
OCR_ENABLED=true
TESSERACT_CMD=